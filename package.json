{
  "name": "events-helper",
  "version": "0.1.0",
  "description": "A durable eve AI agent that tracks tech-conference CfPs and events, matches them to team/personal interests, files them into Jira, and delivers digests and alerts to Slack.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Bronto (https://bronto.io)",
  "homepage": "https://github.com/bronto-community/events-helper#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bronto-community/events-helper.git"
  },
  "bugs": {
    "url": "https://github.com/bronto-community/events-helper/issues"
  },
  "keywords": [
    "eve",
    "ai-agent",
    "call-for-papers",
    "cfp",
    "conferences",
    "events",
    "slack",
    "jira",
    "vercel"
  ],
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "build": "eve build",
    "dev": "eve dev",
    "start": "eve start",
    "typecheck": "tsc",
    "deploy": "sh scripts/deploy.sh",
    "precommit": "sh scripts/precommit.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@vercel/blob": "^2.6.1",
    "@vercel/connect": "0.2.2",
    "@vercel/otel": "^2.1.3",
    "ai": "^7.0.0",
    "eve": "^0.18.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "husky": "^9.1.7",
    "typescript": "7.0.1-rc"
  },
  "overrides": {
    "ai": "^7.0.0"
  },
  "engines": {
    "node": "24.x"
  }
}
